# Credentials — never commit these
credentials/

# Runtime state — noisy, not useful to version
# Note: cron/jobs.json IS versioned (it's config). cron/jobs-state.json and cron/runs/ are runtime.
logs/
cron/jobs-state.json
cron/runs/
tasks/
delivery-queue/
devices/
canvas/
qqbot/
telegram/
media/
memory/
update-check.json
exec-approvals.json
bluebubbles/
plugin-runtime-deps/
plugins/
subagents/

# Session conversation logs and agent runtime state (all agents)
# (Earlier we exempted agents/skills-agent/ when SYSTEM_PROMPT.md and
# DISPATCH.md lived there. Those are gone — the skills-agent's charter
# now lives in its workspace at workspace-skills-agent/AGENTS.md, and
# everything left under agents/skills-agent/ is runtime state.)
agents/


# SQLite runtime databases
flows/
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.db

# Identity/auth
identity/

# Workspace runtime state
workspace/.openclaw/

# ACP agent sub-workspaces (managed by their own sessions)
workspace/claude/
workspace/codex/

# Sub-agent workspaces (each has its own .git for backup per
# docs/concepts/agent-workspace.md §"Git backup"). The wizard initializes
# the nested .git on `openclaw agents add`. Don't double-track here.
workspace-skills-agent/

# Claude Code internal
.claude/

# Old backup files — git replaces these
*.bak
*.bak.*
*.bak[0-9]
*.clobbered.*
*.pre-refactor.*
*.pre-2026-*-fix
*.last-good
openclawbackup.json

# Secrets — never commit
.env

# Temp files in workspace
workspace/tmp-*
workspace/state/
