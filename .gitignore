# Credentials — never commit these
credentials/

# Runtime state — noisy, not useful to version
# Note: cron/jobs.json IS versioned (it's config). cron/jobs-state.json and cron/runs/ are runtime.
logs/
cron/jobs-state.json
cron/runs/
tasks/
delivery-queue/
devices/
canvas/
qqbot/
telegram/
media/
memory/
update-check.json
exec-approvals.json
bluebubbles/
plugin-runtime-deps/
plugins/
subagents/

# Session conversation logs and agent runtime state (all agents)
# Use agents/* + !exception form so the agents/skills-agent/ doc-only
# dispatch contract can be re-included; git can't re-include children of
# a fully-excluded parent directory.
agents/*
!agents/skills-agent/


# SQLite runtime databases
flows/
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.db

# Identity/auth
identity/

# Workspace runtime state
workspace/.openclaw/

# ACP agent sub-workspaces (managed by their own sessions)
workspace/claude/
workspace/codex/

# Claude Code internal
.claude/

# Old backup files — git replaces these
*.bak
*.bak.*
*.bak[0-9]
*.clobbered.*
*.pre-refactor.*
*.pre-2026-*-fix
*.last-good
openclawbackup.json

# Secrets — never commit
.env

# Temp files in workspace
workspace/tmp-*
workspace/state/
